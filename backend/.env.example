# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (leave blank to use SQLite in dev) ───────────────────────────────
